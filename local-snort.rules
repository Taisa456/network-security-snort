# /etc/snort/rules/local.rules
#
# Custom detection rules for the Snort IDS/IPS lab.
# HOME_NET is defined in snort.conf as: 10.10.10.0/24, 192.168.50.0/24
#
# SID range 1000000+ is reserved for local/custom rules.

# -----------------------------------------------------------------
# SID 1000001 - ICMP Ping Detected
# Detects host discovery / reconnaissance pings in either direction.
# -----------------------------------------------------------------
alert icmp any any -> any any ( \
    msg:"ICMP Ping Detected"; \
    sid:1000001; rev:1; )

# -----------------------------------------------------------------
# SID 1000002 - FTP Connection Attempt
# Catches any TCP connection to port 21 — legitimate or otherwise.
# -----------------------------------------------------------------
alert tcp any any -> $HOME_NET 21 ( \
    msg:"FTP Connection Attempt"; \
    flow:to_server,established; \
    sid:1000002; rev:1; )

# -----------------------------------------------------------------
# SID 1000003 - Possible Nmap SYN Scan
# Matches TCP packets with only the SYN flag set — the signature
# of a half-open / SYN scan.
# -----------------------------------------------------------------
alert tcp any any -> $HOME_NET any ( \
    msg:"Possible Nmap SYN Scan"; \
    flags:S; \
    sid:1000003; rev:1; )

# -----------------------------------------------------------------
# SID 1000004 - VSFTPD 2.3.4 Backdoor Attempt
# Matches the ':)' smiley trigger string in the FTP USER payload,
# which is the exact exploit signature for CVE-2011-2523.
# -----------------------------------------------------------------
alert tcp any any -> $HOME_NET 21 ( \
    msg:"VSFTPD 2.3.4 Backdoor Attempt"; \
    flow:to_server,established; \
    content:":)"; \
    sid:1000004; rev:1; )

# -----------------------------------------------------------------
# SID 1000005 - Possible Metasploit Shellcode (NOP Sled)
# Matches an x86 NOP sled (0x90 0x90 0x90) commonly prepended to
# Metasploit payloads to improve landing reliability.
# -----------------------------------------------------------------
alert tcp any any -> $HOME_NET any ( \
    msg:"Possible Metasploit Shellcode (NOP sled)"; \
    content:"|90 90 90|"; \
    sid:1000005; rev:1; )
